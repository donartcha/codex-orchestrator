# Ignore everything by default. This workspace contains multiple projects;
# explicitly unignore only the Codex orchestration config intended for this repo.
/*

# Repo entrypoints
!/.gitignore
!/AGENTS.md
!/README.md
!/.pre-commit-config.yaml
!/docs/
!/docs/codex-prompting-guide.md

# Codex configuration
!/.codex/
!/.codex/**

# Never commit secrets, local environments, caches or generated bytecode.
.codex/context-api/.env
.codex/context-api/.env.*
!.codex/context-api/.env.example
.codex/context-api/*.sqlite3
.codex/context/*.sqlite3
.codex/context/memory-fallback.json
.codex/context-api/.venv/
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/node_modules/
**/dist/
**/build/

# Keep nested project folders out unless explicitly opted in later.
/ArchGraph/
/client/
/CliniCalc/
/nodus/
/server/
/Tarefador/
/tempo/
/ziplink/
