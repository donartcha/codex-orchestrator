CODEX_DB_HOST=localhost
CODEX_DB_PORT=3306
CODEX_DB_NAME=codex_context
CODEX_DB_USER=codex
CODEX_DB_PASSWORD=change_me

# Git agent configuration. Do not store passphrases, tokens or private keys here.
CODEX_GIT_AGENT_CONTEXT_API=.codex/context-api
CODEX_GIT_AGENT_PYTHON=.codex/context-api/.venv/Scripts/python.exe
CODEX_GIT_AGENT_DEFAULT_SIGNING_MODE=auto
CODEX_GIT_AGENT_ALLOW_UNSIGNED_FALLBACK=1

# Optional GitHub API token for local automation such as creating pull requests.
# Keep real tokens only in your untracked .env file.
GITHUB_TOKEN=

# Optional Git signing identity used by .codex/agents/git-agent/AGENT.md.
# Store public key identifiers only; never store passphrases or private key material.
CODEX_GIT_AGENT_SIGNING_KEY=
CODEX_GIT_AGENT_SIGNING_FINGERPRINT=

# Optional NPM token for publishing packages from local automation.
# Keep real tokens only in your untracked .env file.
NPM_TOKEN=
